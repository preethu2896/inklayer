# ── Inklayer Backend Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Email Provider (Resend) ───────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
# Your sender domain MUST be verified in Resend before sending.
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=drops@inklayer.shop

# ── Admin Credentials ─────────────────────────────────────────────────────────
# Change BOTH of these before deploying to production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# ── JWT Settings ──────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, replace with your actual domain (e.g. https://inklayer.shop)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── App Settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
